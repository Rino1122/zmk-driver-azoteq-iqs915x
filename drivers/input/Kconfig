menuconfig INPUT_AZOTEQ_IQS915X
    bool "Azoteq IQS9150/IQS9151 trackpads"
    default y
    depends on GPIO
    depends on I2C
    depends on INPUT
    depends on DT_HAS_AZOTEQ_IQS915X_ENABLED
    help
      Enable driver for Azoteq IQS9150/IQS9151 trackpads.

if INPUT_AZOTEQ_IQS915X

config INPUT_AZOTEQ_IQS915X_INIT_PRIORITY
    int "Azoteq IQS915x initialization priority"
    default INPUT_INIT_PRIORITY
    help
      Driver initialization priority for the IQS915x driver.
      Lower values initialize earlier.

module = INPUT_AZOTEQ_IQS915X
module-str = "Log level for Azoteq IQS915x driver"
source "subsys/logging/Kconfig.template.log_config"


endif # INPUT_AZOTEQ_IQS915X
